# Server Configuration
NODE_ENV=development
PORT=3000

# Database Selection (mongodb | mysql | both)
# - mongodb: only MongoDB adapter
# - mysql: only MySQL adapter
# - both: initialize BOTH adapters; choose per-request using header: x-db-type: mongodb|mysql
DB_TYPE=mongodb
# Default DB when DB_TYPE=both
DB_DEFAULT=mongodb

# MongoDB Configuration
MONGODB_URI=mongodb+srv://nrdeen11:Doodo1020@cluster0.nqs4cjr.mongodb.net/?appName=Cluster0
MONGODB_URI_READ_ONLY=mongodb+srv://nrdeen11:Doodo1020@cluster0.nqs4cjr.mongodb.net/?appName=Cluster0

# MySQL Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=myapp_user
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=myapp
MYSQL_READ_HOST=127.0.0.1
MYSQL_READ_PORT=3306
MYSQL_MAX_POOL=20
MYSQL_READ_MAX_POOL=100

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=10

