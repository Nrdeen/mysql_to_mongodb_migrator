    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const dbType = pm.collectionVariables.get('dbType') || 'mongodb';",
          "pm.collectionVariables.set('dbType', dbType);",
          "pm.request.headers.upsert({ key: 'x-db-type', value: dbType });",
          "",
          "const tokenKey = dbType === 'mysql' ? 'tokenMysql' : 'tokenMongo';",
          "const userIdKey = dbType === 'mysql' ? 'userIdMysql' : 'userIdMongo';",
          "const adminTokenKey = dbType === 'mysql' ? 'adminTokenMysql' : 'adminTokenMongo';",
          "const adminUserIdKey = dbType === 'mysql' ? 'adminUserIdMysql' : 'adminUserIdMongo';",
          "",
          "const t = pm.collectionVariables.get(tokenKey);",
          "if (t) pm.collectionVariables.set('token', t);",
          "const uid = pm.collectionVariables.get(userIdKey);",
          "if (uid) pm.collectionVariables.set('userId', uid);",
          "",
          "const at = pm.collectionVariables.get(adminTokenKey);",
          "if (at) pm.collectionVariables.set('adminToken', at);",
          "const auid = pm.collectionVariables.get(adminUserIdKey);",
          "if (auid) pm.collectionVariables.set('adminUserId', auid);"
        ]
      }
    }
  ],
