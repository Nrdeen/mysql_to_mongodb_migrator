        {
          "name": "Auth - Signup",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = pm.collectionVariables.get('userEmail');",
                  "const password = pm.collectionVariables.get('userPassword');",
                  "if (!email) pm.collectionVariables.set('userEmail', `test+${Date.now()}@example.com`);",
                  "if (!password) pm.collectionVariables.set('userPassword', 'test123456');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const dbType = pm.collectionVariables.get('dbType') || 'mongodb';",
                  "  const tokenKey = dbType === 'mysql' ? 'tokenMysql' : 'tokenMongo';",
                  "  const userIdKey = dbType === 'mysql' ? 'userIdMysql' : 'userIdMongo';",
                  "  const token = json?.data?.token;",
                  "  const user = json?.data?.user;",
                  "  const userId = user?._id ?? user?.id;",
                  "  if (token) pm.collectionVariables.set('token', token);",
                  "  if (token) pm.collectionVariables.set(tokenKey, token);",
                  "  if (userId !== undefined && userId !== null) pm.collectionVariables.set('userId', String(userId));",
                  "  if (userId !== undefined && userId !== null) pm.collectionVariables.set(userIdKey, String(userId));",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"name\": \"Test User\",\n  \"role\": \"user\"\n}"
